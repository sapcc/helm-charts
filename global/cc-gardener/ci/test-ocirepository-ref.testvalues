# Test: ref is set along with tag and repository in values
# Expected: only ref is rendered, repository and tag are null
extensions:
  auditing:
    enabled: true
    version: v0.3.0
    helm:
      ociRepository:
        ref: keppel.example.com/auditing:v1.0.0-custom
        repository: keppel.example.com/should-be-ignored
        tag: v2.0.0-ignored
