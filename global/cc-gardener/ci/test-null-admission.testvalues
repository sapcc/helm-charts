# Test: admission with null values and null ociRepository
# Expected: admission section should be minimal or not rendered
extensions:
  auditing:
    enabled: true
    version: v0.3.0
    admission:
      values:
        image: null
      runtimeCluster:
        helm:
          ociRepository:
            ref: null
            repository: null
            tag: null
      virtualCluster:
        helm:
          ociRepository:
            ref: null
            repository: null
            tag: null
