{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {
          "type": "grafana",
          "uid": "-- Grafana --"
        },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "Dashboard for monitoring Project Calico's calico-kube-controllers, which reconciles Kubernetes resources (nodes, namespaces, policies, service accounts) into the Calico datastore and manages IPAM block assignment.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "gnetId": null,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 0},
      "id": 100,
      "panels": [],
      "title": "Status",
      "type": "row"
    },
    {
      "datasource": {"type": "prometheus", "uid": "$datasource"},
      "description": "Number of calico-kube-controllers replicas currently scraped and up.",
      "fieldConfig": {"defaults": {"unit": "short"}, "overrides": []},
      "gridPos": {"h": 7, "w": 8, "x": 0, "y": 1},
      "id": 101,
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}, "tooltip": {"mode": "single"}},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "$datasource"},
          "expr": "count(up{job=~\".*kube-controllers.*\"} == 1)",
          "legendFormat": "Replicas up",
          "refId": "A"
        }
      ],
      "title": "Replicas up",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "$datasource"},
      "description": "Pod restarts in the last hour. Non-zero indicates crashes or rollouts.",
      "fieldConfig": {"defaults": {"unit": "short"}, "overrides": []},
      "gridPos": {"h": 7, "w": 8, "x": 8, "y": 1},
      "id": 102,
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}, "tooltip": {"mode": "single"}},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "$datasource"},
          "expr": "sum(changes(process_start_time_seconds{job=~\".*kube-controllers.*\"}[1h]))",
          "legendFormat": "Restarts/hr",
          "refId": "A"
        }
      ],
      "title": "Restarts in last 1h",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "$datasource"},
      "description": "Process uptime per replica.",
      "fieldConfig": {"defaults": {"unit": "s"}, "overrides": []},
      "gridPos": {"h": 7, "w": 8, "x": 16, "y": 1},
      "id": 103,
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}, "tooltip": {"mode": "multi"}},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "$datasource"},
          "expr": "time() - process_start_time_seconds{job=~\".*kube-controllers.*\"}",
          "legendFormat": "$instance_label",
          "refId": "A"
        }
      ],
      "title": "Process uptime",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 8},
      "id": 200,
      "panels": [],
      "title": "Workqueues",
      "type": "row"
    },
    {
      "datasource": {"type": "prometheus", "uid": "$datasource"},
      "description": "Current depth of each controller's workqueue. Sustained high depth means the controller is falling behind.",
      "fieldConfig": {"defaults": {"unit": "short"}, "overrides": []},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 9},
      "id": 201,
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}, "tooltip": {"mode": "multi"}},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "$datasource"},
          "expr": "topk($top_n, workqueue_depth{job=~\".*kube-controllers.*\"})",
          "legendFormat": "{{name}}",
          "refId": "A"
        }
      ],
      "title": "Workqueue depth by queue (top $top_n)",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "$datasource"},
      "description": "Rate of items added to each workqueue per second.",
      "fieldConfig": {"defaults": {"unit": "cps"}, "overrides": []},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 9},
      "id": 202,
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}, "tooltip": {"mode": "multi"}},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "$datasource"},
          "expr": "topk($top_n, sum by (name) (rate(workqueue_adds_total{job=~\".*kube-controllers.*\"}[$__rate_interval])))",
          "legendFormat": "{{name}}",
          "refId": "A"
        }
      ],
      "title": "Workqueue adds/sec (top $top_n)",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "$datasource"},
      "description": "99th percentile time items spend waiting in the queue before being processed.",
      "fieldConfig": {"defaults": {"unit": "s"}, "overrides": []},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 17},
      "id": 203,
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}, "tooltip": {"mode": "multi"}},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "$datasource"},
          "expr": "histogram_quantile(0.99, sum by (le, name) (rate(workqueue_queue_duration_seconds_bucket{job=~\".*kube-controllers.*\"}[$__rate_interval])))",
          "legendFormat": "{{name}}",
          "refId": "A"
        }
      ],
      "title": "99%ile queue wait duration",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "$datasource"},
      "description": "99th percentile time the controller spends processing a single item.",
      "fieldConfig": {"defaults": {"unit": "s"}, "overrides": []},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 17},
      "id": 204,
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}, "tooltip": {"mode": "multi"}},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "$datasource"},
          "expr": "histogram_quantile(0.99, sum by (le, name) (rate(workqueue_work_duration_seconds_bucket{job=~\".*kube-controllers.*\"}[$__rate_interval])))",
          "legendFormat": "{{name}}",
          "refId": "A"
        }
      ],
      "title": "99%ile work duration",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "$datasource"},
      "description": "Rate of items that had to be retried. Sustained non-zero usually means a controller is hitting conflict errors against the API server.",
      "fieldConfig": {"defaults": {"unit": "cps"}, "overrides": []},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 25},
      "id": 205,
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}, "tooltip": {"mode": "multi"}},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "$datasource"},
          "expr": "topk($top_n, sum by (name) (rate(workqueue_retries_total{job=~\".*kube-controllers.*\"}[$__rate_interval])))",
          "legendFormat": "{{name}}",
          "refId": "A"
        }
      ],
      "title": "Workqueue retries/sec (top $top_n)",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "$datasource"},
      "description": "How long the oldest unfinished item has been in flight. Stuck values indicate a hung controller goroutine.",
      "fieldConfig": {"defaults": {"unit": "s"}, "overrides": []},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 25},
      "id": 206,
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}, "tooltip": {"mode": "multi"}},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "$datasource"},
          "expr": "topk($top_n, workqueue_longest_running_processor_seconds{job=~\".*kube-controllers.*\"})",
          "legendFormat": "{{name}}",
          "refId": "A"
        }
      ],
      "title": "Longest-running processor (top $top_n)",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 33},
      "id": 300,
      "panels": [],
      "title": "Kubernetes API client",
      "type": "row"
    },
    {
      "datasource": {"type": "prometheus", "uid": "$datasource"},
      "description": "Request rate to the Kubernetes API server, grouped by HTTP response code.",
      "fieldConfig": {"defaults": {"unit": "reqps"}, "overrides": []},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 34},
      "id": 301,
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}, "tooltip": {"mode": "multi"}},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "$datasource"},
          "expr": "sum by (code) (rate(rest_client_requests_total{job=~\".*kube-controllers.*\"}[$__rate_interval]))",
          "legendFormat": "{{code}}",
          "refId": "A"
        }
      ],
      "title": "API requests/sec by code",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "$datasource"},
      "description": "Rate of 5xx and 4xx (non-success) responses from the API server.",
      "fieldConfig": {"defaults": {"unit": "reqps"}, "overrides": []},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 34},
      "id": 302,
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}, "tooltip": {"mode": "multi"}},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "$datasource"},
          "expr": "sum by (code) (rate(rest_client_requests_total{job=~\".*kube-controllers.*\", code!~\"2..\"}[$__rate_interval]))",
          "legendFormat": "{{code}}",
          "refId": "A"
        }
      ],
      "title": "Non-2xx API responses/sec",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "$datasource"},
      "description": "99th percentile latency of API requests, by verb.",
      "fieldConfig": {"defaults": {"unit": "s"}, "overrides": []},
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 42},
      "id": 303,
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}, "tooltip": {"mode": "multi"}},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "$datasource"},
          "expr": "histogram_quantile(0.99, sum by (le, verb) (rate(rest_client_request_duration_seconds_bucket{job=~\".*kube-controllers.*\"}[$__rate_interval])))",
          "legendFormat": "{{verb}}",
          "refId": "A"
        }
      ],
      "title": "99%ile API request latency by verb",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 50},
      "id": 400,
      "panels": [],
      "title": "IPAM",
      "type": "row"
    },
    {
      "datasource": {"type": "prometheus", "uid": "$datasource"},
      "description": "IPAM blocks allocated to each node. Each block holds a /26 (64 IPs) by default.",
      "fieldConfig": {"defaults": {"unit": "short"}, "overrides": []},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 51},
      "id": 401,
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}, "tooltip": {"mode": "multi"}},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "$datasource"},
          "expr": "topk($top_n, ipam_blocks_per_node)",
          "legendFormat": "{{node}}",
          "refId": "A"
        }
      ],
      "title": "IPAM blocks per node (top $top_n)",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "$datasource"},
      "description": "In-use IP allocations per node.",
      "fieldConfig": {"defaults": {"unit": "short"}, "overrides": []},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 51},
      "id": 402,
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}, "tooltip": {"mode": "multi"}},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "$datasource"},
          "expr": "topk($top_n, ipam_allocations_per_node)",
          "legendFormat": "{{node}}",
          "refId": "A"
        }
      ],
      "title": "IP allocations per node (top $top_n)",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "$datasource"},
      "description": "IPs borrowed from another node's block. Non-zero means a node has run out of its own blocks — investigate IPAM pool sizing.",
      "fieldConfig": {"defaults": {"unit": "short"}, "overrides": []},
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 59},
      "id": 403,
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}, "tooltip": {"mode": "multi"}},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "$datasource"},
          "expr": "topk($top_n, ipam_allocations_borrowed_per_node)",
          "legendFormat": "{{node}}",
          "refId": "A"
        }
      ],
      "title": "Borrowed IP allocations per node (top $top_n)",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 67},
      "id": 500,
      "panels": [],
      "title": "Process metrics",
      "type": "row"
    },
    {
      "datasource": {"type": "prometheus", "uid": "$datasource"},
      "description": "CPU seconds used per second by the kube-controllers process.",
      "fieldConfig": {"defaults": {"unit": "percentunit"}, "overrides": []},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 68},
      "id": 501,
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}, "tooltip": {"mode": "multi"}},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "$datasource"},
          "expr": "topk($top_n, rate(process_cpu_seconds_total{job=~\".*kube-controllers.*\"}[$__rate_interval]))",
          "legendFormat": "$instance_label",
          "refId": "A"
        }
      ],
      "title": "CPU usage (top $top_n)",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "$datasource"},
      "description": "Resident set size of the kube-controllers process.",
      "fieldConfig": {"defaults": {"unit": "bytes"}, "overrides": []},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 68},
      "id": 502,
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}, "tooltip": {"mode": "multi"}},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "$datasource"},
          "expr": "topk($top_n, process_resident_memory_bytes{job=~\".*kube-controllers.*\"})",
          "legendFormat": "$instance_label",
          "refId": "A"
        }
      ],
      "title": "Process memory (RSS) (top $top_n)",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "$datasource"},
      "description": "Open file descriptors.",
      "fieldConfig": {"defaults": {"unit": "short"}, "overrides": []},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 76},
      "id": 503,
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}, "tooltip": {"mode": "multi"}},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "$datasource"},
          "expr": "topk($top_n, process_open_fds{job=~\".*kube-controllers.*\"})",
          "legendFormat": "$instance_label",
          "refId": "A"
        }
      ],
      "title": "Open file descriptors (top $top_n)",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "$datasource"},
      "description": "Go garbage collections per minute.",
      "fieldConfig": {"defaults": {"unit": "short"}, "overrides": []},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 76},
      "id": 504,
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}, "tooltip": {"mode": "multi"}},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "$datasource"},
          "expr": "topk($top_n, rate(go_gc_duration_seconds_count{job=~\".*kube-controllers.*\"}[$__rate_interval])) * 60",
          "legendFormat": "$instance_label",
          "refId": "A"
        }
      ],
      "title": "Runtime GC rate/min (top $top_n)",
      "type": "timeseries"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 27,
  "tags": ["kubernetes", "calico", "kube-controllers"],
  "templating": {
